{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nba-prop-engine.local/schemas/local_autonomy_gold.json",
  "title": "LocalAutonomyGold",
  "type": "object",
  "required": ["status", "confidence", "summary", "actions"],
  "properties": {
    "status": { "type": "string", "enum": ["advisory", "hold", "execute"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "summary": { "type": "string" },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action_type", "reason", "confidence"],
        "properties": {
          "action_type": { "type": "string" },
          "reason": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "payload": { "type": "object" }
        }
      }
    }
  },
  "additionalProperties": false
}
