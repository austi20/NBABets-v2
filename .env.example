APP_ENV=dev
DATABASE_URL=sqlite:///data/processed/nba_props.sqlite
DUCKDB_PATH=data/processed/nba_props.duckdb
PROVIDER_CACHE_DB_PATH=data/processed/provider_cache.sqlite
RAW_PAYLOAD_DIR=data/raw
SNAPSHOT_DIR=data/snapshots
REPORTS_DIR=reports
PROVIDER_ROTATION_STATE_PATH=data/snapshots/provider_rotation.json
STARTUP_ETA_HISTORY_PATH=data/snapshots/startup_step_durations.json
FEATURE_VERSION=v1
MODEL_VERSION=v1
TRAINING_SEED=42
ENABLE_PROVIDER_CACHE=true
PROVIDER_CACHE_LOG_OVERLAP_DAYS=2
PROVIDER_CACHE_ODDS_TTL_MINUTES=5
PROVIDER_CACHE_INJURIES_TTL_MINUTES=10
PROVIDER_CACHE_SCHEDULE_TTL_MINUTES=15
PROVIDER_CACHE_ROSTERS_TTL_HOURS=12
PROVIDER_CACHE_ALLOW_PAST_ODDS_REUSE=true
STATS_PROVIDER=balldontlie
STATS_FALLBACK_PROVIDER=none
ODDS_PROVIDER=balldontlie
ODDS_FALLBACK_PROVIDER=none
INJURY_PROVIDER=balldontlie
BALLDONTLIE_API_KEY=3485b14a-01ed-42b3-882a-fa6c0d3f2e0a
# BDL tier cap 600 rpm; default leaves headroom
BALLDONTLIE_MAX_RPM=540
BALLDONTLIE_RATE_WINDOW_SECONDS=60
THESPORTSDB_API_KEY=3485b14a-01ed-42b3-882a-fa6c0d3f2e0a
THE_ODDS_API_KEY=3485b14a-01ed-42b3-882a-fa6c0d3f2e0a
THE_ODDS_API_KEYS=3485b14a-01ed-42b3-882a-fa6c0d3f2e0a
SPORTSGAMEODDS_API_KEY=3485b14a-01ed-42b3-882a-fa6c0d3f2e0a
SPORTSGAMEODDS_API_KEYS=
SPORTSDATAIO_API_KEY=3485b14a-01ed-42b3-882a-fa6c0d3f2e0a
REQUEST_TIMEOUT_SECONDS=30
NBA_API_ENABLE_BOXSCORE_ENRICHMENT=false
NBA_API_BOXSCORE_TIMEOUT_SECONDS=8
NBA_API_BOXSCORE_FETCH_RETRIES=1
NBA_API_BOXSCORE_FETCH_CONCURRENCY=4
DEFAULT_LOOKBACK_GAMES=20
STARTUP_HISTORY_DAYS=90
RUNTIME_MEMORY_FRACTION_LIMIT=0.75
RUNTIME_CPU_FRACTION_LIMIT=0.85
SIMULATION_TARGET_MARGIN=0.01
SIMULATION_MIN_SAMPLES=100000
SIMULATION_MAX_SAMPLES=1000000
SIMULATION_BATCH_SIZE=50000
MINIMUM_PREDICTION_HISTORY_GAMES=3
MINIMUM_PREDICTION_HISTORY_MINUTES=20
# AI summaries (external ClaudeHybridQwen35 runtime or any compatible local llama.cpp service).
AI_LOCAL_ENDPOINT=http://127.0.0.1:8080/v1/chat/completions
AI_LOCAL_MODEL=qwen3-1.7b-q8
AI_LOCAL_API_KEY=local-llamacpp
# Optional app-managed llama.cpp auto-start. Paths can live on any drive.
AI_LOCAL_SERVER_BINARY=C:/Users/<you>/AppData/Local/ClaudeHybridQwen35/bin/llama-server.exe
AI_LOCAL_MODEL_PATH=E:/AI/Models/ClaudeHybridQwen35/model/Qwen3-1.7B-Q8_0.gguf
AI_LOCAL_SERVER_WAIT_SECONDS=45

# Append prompt/response pairs for human-in-the-loop SFT (see llm_train/curricula/SPEC.md)
# LOCAL_AI_LOG_TRAINING=1
AI_TIMEOUT_SECONDS=45
AGENT_MODE=off
AGENT_DEFAULT_DRY_RUN=true
AGENT_BUDGET_TOKENS_DAILY=200000
AGENT_TIMEOUT_SECONDS=45
WORKFLOW_AGENT_ENABLED=true
API_MONITOR_AGENT_ENABLED=true
DATA_QUALITY_AGENT_ENABLED=true
NETWORK_RELIABILITY_AGENT_ENABLED=true
WORKFLOW_AGENT_ERROR_THRESHOLD=5
WORKFLOW_AGENT_ALLOW_AUTO_ACTIONS=false
LOCAL_AUTONOMY_ENABLED=true
LOCAL_AUTONOMY_MIN_CONFIDENCE=0.70
LOCAL_AUTONOMY_MAX_ACTIONS=5
LOCAL_AGENT_POLICY_STATE_PATH=data/snapshots/local_agent_policy.json

# Accuracy examiner (local Qwen): off by default. Set EXAMINER_CSV_PATH to your graded props CSV.
# EXAMINER_ENABLED=false
# EXAMINER_CSV_PATH=data/processed/nba_props_examiner_graded.csv
# EXAMINER_TOP_K=6
# EXAMINER_MIN_CONFIDENCE_FOR_RETRAIN=0.75
# EXAMINER_REAL_ONLY_DEFAULT=true
